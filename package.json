{
    "name": "yaml-schema-checker",
    "version": "0.0.12",
    "description": "A Github action for validating .yaml files using JSON schemas",
    "homepage": "https://github.com/step-security/yaml-schema-checker",
    "main": "src/main.js",
    "author": "step-security",
    "license": "MIT",
    "scripts": {
        "dev": "nodemon --ignore dist/ --exec npm run all",
        "lint": "eslint .",
        "lint-fix": "npx eslint . --fix",
        "build": "ncc build src/main.js -o dist --source-map --license licenses.txt",
        "test": "vitest run --coverage",
        "all": "npm run lint-fix && npm run test && npm run build",
        "update-dependencies": "ncu -u"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/step-security/yaml-schema-checker.git"
    },
    "keywords": [
        "validator",
        "checker",
        "yaml",
        "code-review",
        "json-schema",
        "github-actions"
    ],
    "bugs": {
        "url": "https://github.com/step-security/yaml-schema-checker/issues"
    },
    "engines": {
        "node": ">=24"
    },
    "dependencies": {
        "@actions/core": "3.0.1",
        "axios": "1.17.0",
        "glob": "11.1.0",
        "js-yaml": "4.2.0",
        "jsonschema": "1.4.1"
    },
    "devDependencies": {
        "@eslint/js": "9.1.1",
        "@vercel/ncc": "0.38.1",
        "@vitest/coverage-v8": "^4.1.9",
        "eslint": "9.1.1",
        "globals": "14.0.0",
        "nodemon": "3.1.0",
        "vitest": "^4.1.9"
    }
}
